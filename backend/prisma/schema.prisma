// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Status {
  ACTIVO
  INACTIVO
}

enum POStatus {
  EN_REVISION
  PENDIENTE
  RECIBIDA
  CANCELADA
}

enum MovementType {
  ENTRADA
  SALIDA
  AJUSTE
}

model Warehouse {
  id        String    @id @default(uuid())
  name      String    @unique // Ej. "Materia Prima", "Químicos", etc.
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String    @id @default(uuid())
  sku         String?   @unique
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  
  description String
  category    String
  unit        String    @default("KG")
  unitPrice   Decimal   @db.Decimal(10, 2)
  minStock    Float     @default(0)
  
  // Auditoría y Estado (Soft Delete)
  status      Status    @default(ACTIVO)
  createdBy   String    @default("Sistema")
  updatedBy   String    @default("Sistema")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lots        Lot[]
  movements   Movement[]
  purchaseOrderItems PurchaseOrderItem[]
  adjustments InventoryAdjustment[]

  @@index([warehouseId])
  @@index([status])
}

model Lot {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  
  lotCode     String
  quantity    Decimal   @db.Decimal(10, 2)
  entryDate      DateTime  @default(now())
  expirationDate DateTime?
  
  // Auditoría y Estado (Soft Delete)
  status      Status    @default(ACTIVO)
  createdBy   String    @default("Sistema")
  updatedBy   String    @default("Sistema")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  movements   Movement[]
  purchaseOrderItems PurchaseOrderItem[]
  adjustments InventoryAdjustment[]

  @@index([productId])
}

model Movement {
  id          String       @id @default(uuid())
  productId   String
  product     Product      @relation(fields: [productId], references: [id])
  lotId       String?
  lot         Lot?         @relation(fields: [lotId], references: [id])
  type        MovementType
  quantity    Decimal      @db.Decimal(10, 2)
  previousBalance Decimal? @db.Decimal(10, 2)
  newBalance      Decimal? @db.Decimal(10, 2)
  reason      String       // Ej. "Compra Proveedor", "Despacho Cliente", "Merma"
  reference   String?      // Ej. "OC-001", "GR-002"
  date        DateTime     @default(now())
  
  createdBy   String       @default("Sistema")

  @@index([productId])
  @@index([lotId])
  @@index([date])
}

model Area {
  id        String    @id @default(uuid())
  name      String    @unique // "Gerencia", "Almacen", "Despacho"
  users     User[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  
  areaId    String
  area      Area      @relation(fields: [areaId], references: [id])
  
  status    Status    @default(ACTIVO)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  purchaseOrders PurchaseOrder[]

  @@index([areaId])
}

model Provider {
  id              String    @id @default(uuid())
  razonSocial     String    // Nombre principal
  ruc             String?   @db.VarChar(20)
  nombreComercial String?
  direccion       String?   @db.Text
  estado          Status    @default(ACTIVO)

  contactoNombre  String?
  telefono        String?
  email           String?

  banco           String?
  cuenta          String?
  cci             String?
  
  observaciones   String?   @db.Text

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  purchaseOrders  PurchaseOrder[]
}

model PurchaseOrder {
  id           String   @id @default(uuid())
  orderNumber  String   @unique
  providerId   String
  provider     Provider @relation(fields: [providerId], references: [id])
  
  issueDate    DateTime @default(now())
  expectedDate DateTime?
  status       POStatus @default(EN_REVISION)
  
  quoteNumber  String?  @db.VarChar(50)
  invoiceNumber String? @db.VarChar(50)
  
  includeIgv   Boolean  @default(false)
  subtotal     Decimal  @db.Decimal(10, 2)
  tax          Decimal  @db.Decimal(10, 2)
  shippingCost Decimal  @default(0) @db.Decimal(10, 2)
  total        Decimal  @db.Decimal(10, 2)
  
  notes        String?  @db.Text
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  
  approvedBy   String?
  receivedBy   String?

  items        PurchaseOrderItem[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([providerId])
  @@index([userId])
}

model PurchaseOrderItem {
  id              String   @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  
  lotId           String?
  lot             Lot?     @relation(fields: [lotId], references: [id])
  
  quantity        Decimal  @db.Decimal(10, 2)
  unitPrice       Decimal  @db.Decimal(10, 2)
  totalPrice      Decimal  @db.Decimal(10, 2)

  @@index([purchaseOrderId])
  @@index([productId])
  @@index([lotId])
}

model InventoryAdjustment {
  id               String   @id @default(uuid())
  adjustmentNumber String   @unique @default("AJ-00000")
  productId        String
  product          Product  @relation(fields: [productId], references: [id])
  lotId         String?
  lot           Lot?     @relation(fields: [lotId], references: [id])
  typeDirection String   // 'INGRESO' o 'SALIDA'
  quantity      Decimal  @db.Decimal(10, 2)
  reason        String
  reference     String?
  createdBy     String
  date          DateTime @default(now())

  @@index([productId])
  @@index([lotId])
}
