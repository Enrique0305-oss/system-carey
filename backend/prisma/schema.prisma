// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Status {
  ACTIVO
  INACTIVO
}

enum POStatus {
  EN_REVISION
  PENDIENTE
  RECIBIDA
  CANCELADA
}

enum MovementType {
  ENTRADA
  SALIDA
  AJUSTE
}

model Warehouse {
  id        String    @id @default(uuid())
  name      String    @unique // Ej. "Materia Prima", "Químicos", etc.
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String    @id @default(uuid())
  sku         String?   @unique
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  
  description String
  category    String
  unit        String    @default("KG")
  unitPrice   Decimal   @db.Decimal(10, 2)
  minStock    Float     @default(0)
  
  // Auditoría y Estado (Soft Delete)
  status      Status    @default(ACTIVO)
  createdBy   String    @default("Sistema")
  updatedBy   String    @default("Sistema")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lots        Lot[]
  movements   Movement[]
  purchaseOrderItems PurchaseOrderItem[]
  adjustments InventoryAdjustment[]
  productionInputs  InternalProductionInput[]
  productionOutputs InternalProductionOutput[]
  recipeAsFinal     ProductRecipe? @relation("FinalProductRecipe")
  recipeItemsAsInput ProductRecipeItem[]
  dispatchItems     DispatchItem[]
  internalConsumptionItems InternalConsumptionItem[]

  @@index([warehouseId])
  @@index([status])
}

model Lot {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  
  lotCode     String
  quantity    Decimal   @db.Decimal(10, 2)
  
  providerId  String?
  provider    Provider? @relation(fields: [providerId], references: [id])
  entryDate      DateTime  @default(now())
  expirationDate DateTime?
  
  // Auditoría y Estado (Soft Delete)
  status      Status    @default(ACTIVO)
  createdBy   String    @default("Sistema")
  updatedBy   String    @default("Sistema")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  movements   Movement[]
  purchaseOrderItems PurchaseOrderItem[]
  adjustments InventoryAdjustment[]
  productionInputs  InternalProductionInput[]
  productionOutputs InternalProductionOutput[]
  dispatchItems     DispatchItem[]
  internalConsumptionItems InternalConsumptionItem[]

  @@index([productId])
  @@unique([productId, lotCode])
}

model Movement {
  id          String       @id @default(uuid())
  productId   String
  product     Product      @relation(fields: [productId], references: [id])
  lotId       String?
  lot         Lot?         @relation(fields: [lotId], references: [id])
  type        MovementType
  quantity    Decimal      @db.Decimal(10, 2)
  previousBalance Decimal? @db.Decimal(10, 2)
  newBalance      Decimal? @db.Decimal(10, 2)
  reason      String       // Ej. "Compra Proveedor", "Despacho Cliente", "Merma"
  reference   String?      // Ej. "OC-001", "GR-002"
  date        DateTime     @default(now())
  
  createdBy   String       @default("Sistema")

  @@index([productId])
  @@index([lotId])
  @@index([date])
}

model Area {
  id        String    @id @default(uuid())
  name      String    @unique // "Gerencia", "Almacen", "Despacho"
  users     User[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  
  areaId    String
  area      Area      @relation(fields: [areaId], references: [id])
  
  status    Status    @default(ACTIVO)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  purchaseOrders PurchaseOrder[]

  @@index([areaId])
}

model Provider {
  id              String    @id @default(uuid())
  razonSocial     String    // Nombre principal
  ruc             String?   @db.VarChar(20)
  nombreComercial String?
  direccion       String?   @db.Text
  estado          Status    @default(ACTIVO)

  contactoNombre  String?
  telefono        String?
  email           String?

  banco           String?
  cuenta          String?
  cci             String?
  
  observaciones   String?   @db.Text

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  purchaseOrders  PurchaseOrder[]
  lots            Lot[]
}

model PurchaseOrder {
  id           String   @id @default(uuid())
  orderNumber  String   @unique
  providerId   String
  provider     Provider @relation(fields: [providerId], references: [id])
  
  issueDate    DateTime @default(now())
  expectedDate DateTime?
  status       POStatus @default(EN_REVISION)
  
  quoteNumber  String?  @db.VarChar(50)
  invoiceNumber String? @db.VarChar(50)
  
  includeIgv   Boolean  @default(false)
  subtotal     Decimal  @db.Decimal(10, 2)
  tax          Decimal  @db.Decimal(10, 2)
  shippingCost Decimal  @default(0) @db.Decimal(10, 2)
  total        Decimal  @db.Decimal(10, 2)
  
  notes        String?  @db.Text
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  
  approvedBy   String?
  receivedBy   String?

  items        PurchaseOrderItem[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([providerId])
  @@index([userId])
}

model PurchaseOrderItem {
  id              String   @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  
  lotId           String?
  lot             Lot?     @relation(fields: [lotId], references: [id])
  
  quantity        Decimal  @db.Decimal(10, 2)
  unitPrice       Decimal  @db.Decimal(10, 2)
  totalPrice      Decimal  @db.Decimal(10, 2)

  @@index([purchaseOrderId])
  @@index([productId])
  @@index([lotId])
}

model InventoryAdjustment {
  id               String   @id @default(uuid())
  adjustmentNumber String   @unique @default("AJ-00000")
  productId        String
  product          Product  @relation(fields: [productId], references: [id])
  lotId         String?
  lot           Lot?     @relation(fields: [lotId], references: [id])
  typeDirection String   // 'INGRESO' o 'SALIDA'
  quantity      Decimal  @db.Decimal(10, 2)
  reason        String
  reference     String?
  createdBy     String
  date          DateTime @default(now())

  @@index([productId])
  @@index([lotId])
}

model InternalProduction {
  id               String   @id @default(uuid())
  productionNumber String   @unique @default("PR-00000")
  date             DateTime @default(now())
  status           String   @default("COMPLETADO") // PENDIENTE o COMPLETADO
  createdBy        String
  
  inputs           InternalProductionInput[]
  outputs          InternalProductionOutput[]
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model InternalProductionInput {
  id                   String   @id @default(uuid())
  internalProductionId String
  internalProduction   InternalProduction @relation(fields: [internalProductionId], references: [id], onDelete: Cascade)
  
  productId            String
  product              Product  @relation(fields: [productId], references: [id])
  lotId                String
  lot                  Lot      @relation(fields: [lotId], references: [id])
  
  quantity             Decimal  @db.Decimal(10, 2)
  
  @@index([internalProductionId])
  @@index([productId])
  @@index([lotId])
}

model InternalProductionOutput {
  id                   String   @id @default(uuid())
  internalProductionId String
  internalProduction   InternalProduction @relation(fields: [internalProductionId], references: [id], onDelete: Cascade)
  
  productId            String
  product              Product  @relation(fields: [productId], references: [id])
  lotId                String
  lot                  Lot      @relation(fields: [lotId], references: [id])
  
  quantity             Decimal  @db.Decimal(10, 2)
  
  @@index([internalProductionId])
  @@index([productId])
  @@index([lotId])
}

model ProductRecipe {
  id              String   @id @default(uuid())
  finalProductId  String   @unique
  finalProduct    Product  @relation("FinalProductRecipe", fields: [finalProductId], references: [id])
  
  items           ProductRecipeItem[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ProductRecipeItem {
  id              String   @id @default(uuid())
  recipeId        String
  recipe          ProductRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  
  inputId         String
  inputProduct    Product  @relation(fields: [inputId], references: [id])
  
  quantity        Decimal  @db.Decimal(10, 4) // Cantidad requerida para hacer 1 unidad del producto final
  
  @@unique([recipeId, inputId])
}

model Client {
  id              String    @id @default(uuid())
  razonSocial     String
  ruc             String?   @db.VarChar(20)
  direccion       String?   @db.Text
  telefono        String?
  email           String?
  estado          Status    @default(ACTIVO)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  dispatches      Dispatch[]
}

model Dispatch {
  id               String   @id @default(uuid())
  dispatchNumber   String   @unique @default("D-00000")
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id])
  date             DateTime @default(now())
  status           String   @default("COMPLETADO")
  createdBy        String
  
  items            DispatchItem[]
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  @@index([clientId])
}

model DispatchItem {
  id              String   @id @default(uuid())
  dispatchId      String
  dispatch        Dispatch @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  lotId           String
  lot             Lot      @relation(fields: [lotId], references: [id])
  
  quantity        Decimal  @db.Decimal(10, 2)
  
  @@index([dispatchId])
  @@index([productId])
  @@index([lotId])
}

model InternalConsumption {
  id                  String   @id @default(uuid())
  consumptionNumber   String   @unique @default("CI-00000")
  date                DateTime @default(now())
  status              String   @default("COMPLETADO")
  reason              String?  @db.Text
  createdBy           String
  
  items               InternalConsumptionItem[]
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model InternalConsumptionItem {
  id                    String   @id @default(uuid())
  internalConsumptionId String
  internalConsumption   InternalConsumption @relation(fields: [internalConsumptionId], references: [id], onDelete: Cascade)
  
  productId             String
  product               Product  @relation(fields: [productId], references: [id])
  lotId                 String
  lot                   Lot      @relation(fields: [lotId], references: [id])
  
  quantity              Decimal  @db.Decimal(10, 2)
  
  @@index([internalConsumptionId])
  @@index([productId])
  @@index([lotId])
}
